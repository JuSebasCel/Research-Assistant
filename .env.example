# --- Entorno ---
ENVIRONMENT=development
LOG_LEVEL=INFO

# --- Qdrant (usar defaults para desarrollo local) ---
# QDRANT_HOST=localhost
# QDRANT_PORT=6333
# QDRANT_COLLECTION_NAME=scientific_papers

# --- Embeddings (usar defaults del modelo e5-large) ---
# EMBEDDING_MODEL_NAME=intfloat/multilingual-e5-large
# EMBEDDING_DIMENSION=1024

# --- Gemini (LLM) ---
# GEMINI_API_KEY=tu-api-key-aqui  # gratis, sin tarjeta: https://aistudio.google.com/apikey
# GEMINI_MODEL_NAME=gemini-flash-latest
